# Turso (libSQL) credentials. Leave these unset to use the local ./data/*.db files.
# Get these from https://turso.tech (create one database per dataset).
TURSO_AUTH_TOKEN=
TURSO_URL_EN=libsql://your-english-bible-db.turso.io
TURSO_URL_TA=libsql://your-tamil-bible-db.turso.io
TURSO_URL_SONGS=libsql://your-songs-db.turso.io
